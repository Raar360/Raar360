            "character": "leo",
            "pose": "standing",
            "expression": "gentle",
            "position": "left"
          },
          {
            "id": "pip-09",
            "character": "pip",
            "pose": "floating",
            "expression": "gentle",
            "position": "right"
          },
          {
            "id": "dad-09",
            "character": "dad",
            "pose": "doorway",
            "expression": "gentle",
            "position": "far-right",
            "transform": { "scale": 0.9, "zIndex": 10 }
          }
        ],
        "props": [
