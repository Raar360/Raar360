            "transform": { "scale": 1.6, "zIndex": 12 }
          }
        ],
        "dialogue": "narration"
      },
      "text": "Pip looked closely.\n\n\"Hmm…\"\n\n\"What?\"\n\n\"It doesn't have anywhere for the captain to sit.\"\n\nLeo gasped.\n\n\"It needs seats!\"\n\n\"And buttons!\"\n\n\"And a snack cupboard!\""
    },
    {
      "id": "page-07",
      "scene": {
        "id": "scene-07",
        "background": { "id": "leo-bedroom-spaceship", "category": "background" },
        "characters": [
