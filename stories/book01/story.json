            "pose": "skipping",
            "expression": "neutral",
            "position": "right"
          },
          {
            "id": "dad-02",
            "character": "dad",
            "pose": "kitchen-call",
            "expression": "smiling",
            "position": "far-right",
            "transform": { "scale": 0.85, "zIndex": 10 }
          }
        ],
        "dialogue": "mixed",
        "speechBubbles": [
          {
            "id": "dad-bubble",
            "asset": { "id": "shout-bubble", "category": "speech-bubble" },
            "position": { "x": 75, "y": 35 },
            "text": "Morning, Leo!"
          }
        ]
      },
      "text": "As they tiptoed down the hallway, Dad called from the kitchen.\n\n\"Morning, Leo! Shoes on please, we're leaving soon.\"\n\n\"Okay!\" called Leo.\n\nHe really meant it.\n\nLeo turned towards the front door.\n\nPip skipped beside him."
    },
    {
